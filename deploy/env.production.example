# Production / Testing 伺服器用（複製到伺服器後改名 .env）
# Testing: PORT=5239, DB 用 dev
# Production: PORT=5240, DB 用 prod

PORT=5240
MONGODB_URI=mongodb+srv://USER:PASS@cluster.mongodb.net/pickleball_tournament
SESSION_SECRET=請改成長隨機字串
NODE_ENV=production

# BOOTSTRAP_ADMIN_EMAIL=admin@example.com
# BOOTSTRAP_ADMIN_PASSWORD=請改密碼
# BOOTSTRAP_ADMIN_NAME=系統管理員

# 首頁 / 自動轉去大會小組報分表（留空則顯示平台首頁）
# HOME_REDIRECT=/e/match-ap-2026#standings
