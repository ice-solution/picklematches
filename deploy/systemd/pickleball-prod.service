[Unit]
Description=Pickleball Tournament (Production - match.picklevibes.hk)
After=network.target

[Service]
Type=simple
User=www-data
Group=www-data
WorkingDirectory=/var/www/pickleball-prod
EnvironmentFile=/var/www/pickleball-prod/.env
Environment=NODE_ENV=production
ExecStart=/usr/bin/node src/server.js
Restart=on-failure
RestartSec=5

[Install]
WantedBy=multi-user.target
