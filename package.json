{
  "name": "pickleball-tournament",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "predev": "npm run build:css",
    "dev": "node --watch src/server.js",
    "start": "node src/server.js",
    "build": "npm run build:css",
    "build:css": "tailwindcss -i ./src/input.css -o ./public/css/styles.css --minify",
    "build:css:dev": "tailwindcss -i ./src/input.css -o ./public/css/styles.css --watch",
    "seed": "node scripts/seed.js",
    "db:clear": "node scripts/clearDb.js --yes",
    "db:set-tournament-dates": "node scripts/set-event-tournament-dates.js",
    "db:sync-team-codes": "node scripts/sync-event-team-codes.js"
  },
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "connect-mongo": "^5.1.0",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "ejs": "^3.1.10",
    "express": "^4.21.1",
    "express-session": "^1.18.1",
    "helmet": "^7.1.0",
    "method-override": "^3.0.0",
    "mongoose": "^8.8.3",
    "multer": "^1.4.5-lts.1",
    "socket.io": "^4.8.1",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "autoprefixer": "^10.4.20",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.15"
  }
}
