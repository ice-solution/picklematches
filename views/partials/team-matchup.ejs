<%
  var ta = typeof teamA !== 'undefined' ? teamA : null;
  var tb = typeof teamB !== 'undefined' ? teamB : null;
  var layout = typeof layout !== 'undefined' ? layout : 'flex';
  var nameTruncateClass = 'team-matchup-name';
%>
<% if (layout === 'grid') { %>
<div class="team-matchup-grid">
  <div class="team-matchup-side team-matchup-side--a">
    <%- include('team-display', { team: ta, align: 'left', secondaryClass: nameTruncateClass }) %>
  </div>
  <span class="team-matchup-vs">vs</span>
  <div class="team-matchup-side team-matchup-side--b">
    <%- include('team-display', { team: tb, align: 'right', secondaryClass: nameTruncateClass }) %>
  </div>
</div>
<% } else { %>
<%
  var wrapClass =
    typeof wrapClass !== 'undefined' && wrapClass
      ? wrapClass
      : 'team-matchup team-matchup--flex';
  var vsClass =
    typeof vsClass !== 'undefined' && vsClass ? vsClass : 'team-matchup-vs';
%>
<div class="<%= wrapClass %>">
  <div class="team-matchup-side team-matchup-side--a">
    <%- include('team-display', { team: ta, align: 'left', secondaryClass: nameTruncateClass }) %>
  </div>
  <span class="<%= vsClass %>">vs</span>
  <div class="team-matchup-side team-matchup-side--b">
    <%- include('team-display', { team: tb, align: 'right', secondaryClass: nameTruncateClass }) %>
  </div>
</div>
<% } %>
