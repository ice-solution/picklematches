<% var panelHidden = (typeof activeCompKey !== 'undefined' && activeCompKey !== comp.key) || (typeof activeDateKey !== 'undefined' && activeDateKey !== dateKey); %>
<div
  class="competition-panel mt-10 <%= panelHidden ? 'hidden' : '' %>"
  data-comp-key="<%= comp.key %>"
  data-date-key="<%= dateKey %>"
  id="comp-<%= comp.key %>"
>
  <header class="border-b border-slate-800 pb-4">
    <h2 class="text-2xl font-bold text-white"><%= comp.name %></h2>
    <% if (typeof isOrphanKnockout !== 'undefined' && isOrphanKnockout) { %>
      <p class="mt-1 text-sm text-slate-400">淘汰賽</p>
    <% } %>
  </header>

  <% if (comp.hasKnockout && comp.podium) { %>
  <section class="mt-8 max-w-2xl">
    <%- include('podium-display', { podium: comp.podium }) %>
  </section>
  <% } else if (typeof isOrphanKnockout !== 'undefined' && isOrphanKnockout && comp.podium) { %>
  <section class="mt-8 max-w-2xl">
    <%- include('podium-display', { podium: comp.podium }) %>
  </section>
  <% } %>

  <% if (comp.standings) { %>
  <div class="comp-standings mt-8">
    <%- include('group-standings', {
      groupStandingsList: [comp.standings],
      highlightTeam: typeof highlightTeam !== 'undefined' ? highlightTeam : '',
      hideSectionHeading: true,
    }) %>
  </div>
  <% } %>

  <% if (comp.roundRobinMatrices && comp.roundRobinMatrices.length) { %>
    <%- include('group-round-robin-matrix', {
      groupRoundRobinMatrices: comp.roundRobinMatrices,
      publicMode: true,
      event: event,
    }) %>
  <% } %>

  <%- include('knockout-ladder-public', {
    knockoutLadderColumns: comp.knockoutLadderColumns,
    event: event,
  }) %>

  <section class="comp-schedule mt-10 overflow-x-auto">
    <div class="flex flex-wrap items-end justify-between gap-4">
      <h3 class="text-lg font-semibold text-white">賽程與結果</h3>
      <% if (comp.hasKnockout) { %>
      <div class="flex flex-wrap gap-2 text-xs" role="tablist">
        <button type="button" class="phase-filter rounded bg-emerald-800/70 px-3 py-1.5 font-semibold text-white" data-phase="all">全部</button>
        <button type="button" class="phase-filter rounded border border-slate-600 px-3 py-1.5 text-slate-300" data-phase="group">小組</button>
        <button type="button" class="phase-filter rounded border border-slate-600 px-3 py-1.5 text-slate-300" data-phase="knockout">淘汰</button>
      </div>
      <% } %>
    </div>
    <div class="mt-4">
      <%- include('event-schedule-table', { matches: comp.matches, event: event }) %>
    </div>
  </section>
</div>
