<% if (typeof knockoutLadderColumns !== 'undefined' && knockoutLadderColumns && knockoutLadderColumns.length) { %>
<section class="knockout-ladder mt-8 rounded border border-amber-900/45 bg-amber-950/15 p-5" aria-label="淘汰賽程表">
  <h3 class="text-base font-semibold text-amber-200">淘汰賽程</h3>
  <div class="mt-5 overflow-x-auto pb-2">
    <div class="flex min-w-min items-stretch">
      <% knockoutLadderColumns.forEach(function (col, idx) { %>
        <% if (idx > 0) { %>
          <div class="flex w-9 shrink-0 items-center justify-center self-stretch text-lg text-slate-600 select-none" aria-hidden="true">→</div>
        <% } %>
        <div class="flex w-52 shrink-0 flex-col border border-slate-800/90 bg-slate-950/60 p-3">
          <div class="border-b border-amber-800/40 pb-2 text-center text-xs font-semibold uppercase tracking-wide text-amber-300/95"><%= col.label %></div>
          <div class="mt-3 flex flex-col gap-4">
            <% col.matches.forEach(function (m) { %>
              <div class="knockout-match-card rounded border border-slate-700/80 bg-slate-900/50 px-2 py-3 text-xs">
                <div class="flex items-stretch gap-1">
                  <div class="flex flex-1 flex-col items-end text-right text-slate-200">
                    <%- include('team-display', { team: m.teamA, align: 'right', primaryClass: 'font-medium text-slate-200', secondaryClass: 'block text-[10px] text-slate-500' }) %>
                  </div>
                  <div class="relative flex w-7 shrink-0 flex-col items-center justify-center">
                    <span class="absolute left-0 right-0 top-1/2 border-t border-slate-600"></span>
                    <span class="relative z-[1] bg-slate-900/90 px-0.5 text-[10px] text-slate-500">vs</span>
                  </div>
                  <div class="flex flex-1 flex-col items-start text-left text-slate-200">
                    <%- include('team-display', { team: m.teamB, align: 'left', primaryClass: 'font-medium text-slate-200', secondaryClass: 'block text-[10px] text-slate-500' }) %>
                  </div>
                </div>
                <div class="mt-2">
                  <%- include('score-display', {
                    m: m,
                    scoreMainClass: 'font-mono text-sm font-bold tabular-nums text-emerald-300',
                    scoreDetailClass: 'mt-0.5 block font-mono text-[10px] text-emerald-300/75',
                  }) %>
                </div>
                <% if (m.status === 'finished' && m.winnerId && (m.winnerId.name || m.winnerId._id)) { %>
                  <p class="mt-1 text-center text-[10px] text-emerald-500/95">勝：<%- include('team-display', { team: m.winnerId, align: 'center', primaryClass: 'font-medium text-emerald-400/95', secondaryClass: 'block text-[9px] text-emerald-500/70' }) %></p>
                <% } %>
                <a href="/e/<%= event.slug %>/screen/<%= m._id %>" class="mt-2 block text-center text-sky-400 underline" target="_blank" rel="noopener">直播</a>
              </div>
            <% }); %>
          </div>
        </div>
      <% }); %>
    </div>
  </div>
</section>
<% } %>
