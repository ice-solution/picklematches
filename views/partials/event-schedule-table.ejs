<% var matchList = matches || []; %>

<!-- 手機：卡片 -->
<div class="schedule-cards md:hidden space-y-3">
  <% if (!matchList.length) { %>
    <p class="rounded border border-slate-800 bg-slate-900/40 py-8 text-center text-sm text-slate-500">此篩選尚無場次</p>
  <% } %>
  <% matchList.forEach(function (m) { %>
    <article
      class="schedule-match-row rounded-lg border border-slate-800 bg-slate-900/50 p-4"
      data-id="<%= m._id %>"
      data-phase="<%= m.tournamentPhase || '' %>"
    >
      <div class="flex items-start justify-between gap-2">
        <div class="min-w-0 flex-1">
          <p class="text-xs text-slate-500">
            <%= m.tournamentPhase === 'knockout' ? '淘汰' : '小組' %>
            <% if (m.scheduleGroupLabel) { %> · <%= m.scheduleGroupLabel %><% } %>
          </p>
          <p class="mt-1 font-mono text-sm text-sky-300/90">
            <%= typeof displayMatchSchedule === 'function' ? displayMatchSchedule(m) : displayMatchTime(m) %>
            <% if (m.court) { %> · <%= m.court %><% } %>
          </p>
        </div>
        <span class="shrink-0 rounded bg-slate-800 px-2 py-0.5 text-xs text-slate-300">
          <%= typeof matchStatusLabel === 'function' ? matchStatusLabel(m.status) : m.status %>
        </span>
      </div>
      <div class="mt-3 grid grid-cols-[1fr_auto_1fr] items-center gap-2 text-sm">
        <div class="text-right">
          <%- include('team-display', { team: m.teamA, align: 'right' }) %>
        </div>
        <span class="text-center text-xs font-bold text-slate-500">VS</span>
        <div>
          <%- include('team-display', { team: m.teamB, align: 'left' }) %>
        </div>
      </div>
      <div class="mt-3 flex items-center justify-between gap-2 border-t border-slate-800/80 pt-3">
        <div class="score-cell text-sm">
          <%- include('score-display', { m: m, scoreMainClass: 'font-mono font-semibold text-emerald-300', scoreDetailClass: 'mt-0.5 block font-mono text-xs text-slate-400' }) %>
        </div>
        <a
          class="shrink-0 rounded bg-emerald-800/80 px-3 py-2 text-xs font-semibold text-white"
          href="/e/<%= event.slug %>/screen/<%= m._id %>"
          target="_blank"
          rel="noopener"
        >直播</a>
      </div>
    </article>
  <% }); %>
</div>

<!-- 桌面：表格 -->
<div class="schedule-table-wrap hidden overflow-x-auto md:block">
  <table class="event-schedule-table w-full min-w-[720px] text-left text-sm">
    <thead>
      <tr class="border-b border-slate-800 text-slate-400">
        <th class="py-2 pr-3">直播</th>
        <th class="py-2 pr-3">階段</th>
        <th class="py-2 pr-3">輪次</th>
        <th class="py-2 pr-3">日期／時間</th>
        <th class="py-2 pr-3">場地</th>
        <th class="py-2 pr-3">隊伍 A</th>
        <th class="py-2 pr-3">隊伍 B</th>
        <th class="py-2 pr-3">比分</th>
        <th class="py-2">狀態</th>
      </tr>
    </thead>
    <tbody>
      <% if (!matchList.length) { %>
        <tr><td colspan="9" class="py-8 text-center text-slate-500">此篩選尚無場次</td></tr>
      <% } %>
      <% matchList.forEach(function (m) { %>
        <tr
          class="schedule-match-row border-b border-slate-800/80"
          data-id="<%= m._id %>"
          data-phase="<%= m.tournamentPhase || '' %>"
        >
          <td class="py-2.5 pr-3">
            <a class="inline-block whitespace-nowrap rounded bg-slate-800 px-2.5 py-1 text-xs font-semibold text-slate-100 hover:bg-slate-700" href="/e/<%= event.slug %>/screen/<%= m._id %>" target="_blank" rel="noopener">直播</a>
          </td>
          <td class="py-2.5 pr-3 text-slate-300"><%= m.tournamentPhase === 'knockout' ? '淘汰' : '小組' %></td>
          <td class="py-2.5 pr-3 text-slate-400"><%= m.scheduleGroupLabel || '—' %></td>
          <td class="py-2.5 pr-3 font-mono text-xs text-slate-300"><%= typeof displayMatchSchedule === 'function' ? displayMatchSchedule(m) : displayMatchTime(m) %></td>
          <td class="py-2.5 pr-3 text-slate-300"><%= m.court || '—' %></td>
          <td class="max-w-[10rem] py-2.5 pr-3 text-sm leading-snug"><%- include('team-display', { team: m.teamA }) %></td>
          <td class="max-w-[10rem] py-2.5 pr-3 text-sm leading-snug"><%- include('team-display', { team: m.teamB }) %></td>
          <td class="py-2.5 pr-3 score-cell"><%- include('score-display', { m: m, scoreMainClass: 'font-mono text-sm font-semibold text-emerald-300', scoreDetailClass: 'mt-0.5 block font-mono text-xs text-slate-400' }) %></td>
          <td class="py-2.5 whitespace-nowrap"><%= typeof matchStatusLabel === 'function' ? matchStatusLabel(m.status) : m.status %></td>
        </tr>
      <% }); %>
    </tbody>
  </table>
</div>
