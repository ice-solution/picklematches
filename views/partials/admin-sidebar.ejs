<% var path = typeof adminPath !== 'undefined' ? adminPath : ''; %>
<% var ev = typeof event !== 'undefined' ? event : null; %>
<% var tn = typeof tournament !== 'undefined' ? tournament : null; %>
<aside class="admin-sidebar">
  <div class="border-b border-slate-800 p-4">
    <p class="text-xs font-semibold uppercase tracking-wider text-slate-500">管理後台</p>
    <p class="mt-1 text-sm text-emerald-400">匹克球計分 v0.2</p>
  </div>
  <nav class="flex-1 space-y-1 overflow-y-auto p-3 text-sm">
    <p class="px-2 py-1 text-xs font-semibold text-slate-500">功能選單</p>
    <a href="/admin" class="block rounded px-3 py-2 <%= path === '/admin' ? 'bg-slate-800 font-medium text-white' : 'text-slate-300 hover:bg-slate-800/80' %>">大會列表</a>
    <a href="/admin/events/new" class="block rounded px-3 py-2 <%= path === '/admin/events/new' ? 'bg-slate-800 font-medium text-white' : 'text-slate-300 hover:bg-slate-800/80' %>">新增大會</a>
    <a href="/admin/referees" class="block rounded px-3 py-2 <%= path === '/admin/referees' ? 'bg-slate-800 font-medium text-white' : 'text-slate-300 hover:bg-slate-800/80' %>">球證管理</a>
    <% if (ev && ev._id) { %>
      <p class="mt-3 px-2 py-1 text-xs font-semibold text-slate-500">目前大會</p>
      <a href="/admin/events/<%= ev._id %>" class="block rounded px-3 py-2 <%= path === '/admin/events/' + String(ev._id) ? 'bg-slate-800 font-medium text-white' : 'text-slate-300 hover:bg-slate-800/80' %>">大會設定</a>
      <a href="/admin/events/<%= ev._id %>/matches-summary" class="block rounded px-3 py-2 <%= path.indexOf('/admin/events/' + String(ev._id) + '/matches-summary') === 0 ? 'bg-slate-800 font-medium text-white' : 'text-slate-300 hover:bg-slate-800/80' %>">賽果／報分表</a>
      <a href="/e/<%= ev.slug %>#standings" target="_blank" rel="noopener" class="block rounded px-3 py-2 text-slate-400 hover:bg-slate-800/80">觀眾報分表 ↗</a>
      <a href="/admin/events/<%= ev._id %>/scoreboard" class="block rounded px-3 py-2 <%= path.indexOf('/admin/events/' + String(ev._id) + '/scoreboard') === 0 ? 'bg-slate-800 font-medium text-white' : 'text-slate-300 hover:bg-slate-800/80' %>">大會計分牌</a>
      <a href="/e/<%= ev.slug %>/scoreboard" target="_blank" rel="noopener" class="block rounded px-3 py-2 text-slate-400 hover:bg-slate-800/80">直播計分牌 ↗</a>
      <a href="/e/<%= ev.slug %>" target="_blank" rel="noopener" class="block rounded px-3 py-2 text-slate-400 hover:bg-slate-800/80">開啟前台 ↗</a>
    <% } %>
    <% if (tn && tn._id) { %>
      <p class="mt-3 px-2 py-1 text-xs font-semibold text-slate-500">目前賽事</p>
      <a href="/admin/tournaments/<%= tn._id %>" class="block rounded px-3 py-2 <%= path === '/admin/tournaments/' + String(tn._id) ? 'bg-slate-800 font-medium text-white' : 'text-slate-300 hover:bg-slate-800/80' %>">賽程／隊伍／匯入</a>
    <% } %>
    <p class="mt-4 px-2 py-1 text-xs font-semibold text-slate-500">說明文件</p>
    <a href="/docs/features.md" target="_blank" rel="noopener" class="block rounded px-3 py-2 text-slate-300 hover:bg-slate-800/80">功能一覽</a>
    <a href="/docs/xlsx-import-format.md" target="_blank" rel="noopener" class="block rounded px-3 py-2 text-slate-300 hover:bg-slate-800/80">Excel 匯入格式</a>
  </nav>
  <div class="border-t border-slate-800 p-3 text-xs text-slate-500">
    <p class="truncate" title="<%= typeof userEmail !== 'undefined' ? userEmail : '' %>"><%= typeof userEmail !== 'undefined' ? userEmail : '' %></p>
    <form method="post" action="/admin/logout" class="mt-2">
      <button type="submit" class="text-amber-400 underline">登出</button>
    </form>
  </div>
</aside>
