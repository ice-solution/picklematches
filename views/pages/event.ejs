<%- include('../partials/head', { title: event.name }) %>
<body class="min-h-screen bg-slate-950 text-slate-100 font-sans">
  <main class="mx-auto max-w-5xl px-4 py-10">
    <header class="border-b border-slate-800 pb-6">
      <h1 class="text-2xl font-bold text-emerald-400"><%= event.name %></h1>
      <p class="mt-2 text-sm text-slate-400">即時更新（比分變更後自動刷新）</p>
      <% if (typeof groupStandingsList !== 'undefined' && groupStandingsList && groupStandingsList.length) { %>
      <nav class="mt-4 flex flex-wrap gap-3 text-sm">
        <a href="#standings" class="rounded bg-emerald-800/60 px-3 py-1.5 font-semibold text-emerald-100 hover:bg-emerald-700/60">小組報分表</a>
        <a href="#schedule" class="rounded border border-slate-700 px-3 py-1.5 text-slate-300 hover:bg-slate-800">賽程表</a>
      </nav>
      <% } %>
    </header>

    <%- include('../partials/group-standings', { groupStandingsList: typeof groupStandingsList !== 'undefined' ? groupStandingsList : [], highlightTeam: typeof highlightTeam !== 'undefined' ? highlightTeam : '' }) %>

    <section id="schedule" class="mt-10 overflow-x-auto">
      <h2 class="mb-4 text-xl font-bold text-white">賽程表</h2>
      <table class="w-full min-w-[960px] text-left text-sm">
        <thead>
          <tr class="border-b border-slate-800 text-slate-400">
            <th class="py-2 pr-4">直播比分頁</th>
            <th class="py-2 pr-4">比賽組別</th>
            <th class="py-2 pr-4">開賽</th>
            <th class="py-2 pr-4">場地</th>
            <th class="py-2 pr-4">隊伍 A</th>
            <th class="py-2 pr-4">隊伍 B</th>
            <th class="py-2 pr-4">比分</th>
            <th class="py-2">狀態</th>
          </tr>
        </thead>
        <tbody id="match-rows">
          <% matches.forEach(function (m) { %>
            <tr class="border-b border-slate-800/80 match-row" data-id="<%= m._id %>">
              <td class="py-3 pr-4">
                <a
                  class="inline-block rounded bg-slate-800 px-3 py-1.5 text-xs font-semibold text-slate-100 hover:bg-slate-700"
                  href="/e/<%= event.slug %>/screen/<%= m._id %>"
                  target="_blank"
                  rel="noopener"
                >開啟直播</a>
              </td>
              <td class="py-3 pr-4 text-slate-200">
                <% var divLabel = [m.tournamentName, m.scheduleGroupLabel].filter(Boolean).join(' · '); %>
                <%= divLabel || '—' %>
              </td>
              <td class="py-3 pr-4 font-mono text-slate-300"><%= displayMatchTime(m) %></td>
              <td class="py-3 pr-4 text-slate-300"><%= m.court || '—' %></td>
              <td class="py-3 pr-4"><%= m.teamA && m.teamA.name ? m.teamA.name : '—' %></td>
              <td class="py-3 pr-4"><%= m.teamB && m.teamB.name ? m.teamB.name : '—' %></td>
              <td class="py-3 pr-4 score-cell"><%- include('../partials/score-display', { m: m, scoreMainClass: 'font-mono text-sm font-semibold text-emerald-300', scoreDetailClass: 'mt-0.5 block font-mono text-xs text-slate-400' }) %></td>
              <td class="py-3"><%= m.status %></td>
            </tr>
          <% }); %>
        </tbody>
      </table>
    </section>
    <p class="mt-8 text-center">
      <a class="text-emerald-400 underline" href="/">首頁</a>
    </p>
  </main>
  <script src="/socket.io/socket.io.js"></script>
  <script>
    (function () {
      var eventId = <%- JSON.stringify(eventIdStr) %>;
      var initialTeam = <%- JSON.stringify(typeof highlightTeam !== 'undefined' ? highlightTeam : '') %>;

      function norm(s) {
        return String(s || '').trim().toLowerCase();
      }

      function applyTeamHighlight(query) {
        var q = norm(query);
        var rows = document.querySelectorAll('.standings-row');
        var msg = document.getElementById('team-lookup-msg');
        rows.forEach(function (tr) {
          var name = tr.getAttribute('data-team') || '';
          var match = q && (norm(name) === q || norm(name).indexOf(q) !== -1 || q.indexOf(norm(name)) !== -1);
          tr.classList.toggle('ring-2', !!match);
          tr.classList.toggle('ring-amber-400', !!match);
          tr.classList.toggle('bg-amber-950/40', !!match);
        });
        if (!msg) return;
        if (!q) {
          msg.classList.add('hidden');
          msg.textContent = '';
          return;
        }
        var hit = document.querySelector('.standings-row.ring-amber-400');
        if (hit) {
          var rank = hit.getAttribute('data-rank');
          var group = hit.getAttribute('data-group');
          var team = hit.getAttribute('data-team');
          msg.textContent = team + '：' + group + ' 第 ' + rank + ' 名';
          msg.classList.remove('hidden');
          hit.scrollIntoView({ behavior: 'smooth', block: 'center' });
        } else {
          msg.textContent = '找不到隊伍「' + query + '」，請檢查名稱是否與報分表完全一致。';
          msg.classList.remove('hidden');
        }
      }

      var form = document.getElementById('team-lookup-form');
      if (form) {
        form.addEventListener('submit', function (e) {
          e.preventDefault();
          var input = document.getElementById('team-lookup-input');
          var v = input ? input.value.trim() : '';
          if (v) {
            var url = new URL(window.location.href);
            url.searchParams.set('team', v);
            window.history.replaceState({}, '', url);
          }
          applyTeamHighlight(v);
        });
        var clearBtn = document.getElementById('team-lookup-clear');
        if (clearBtn) {
          clearBtn.addEventListener('click', function () {
            var input = document.getElementById('team-lookup-input');
            if (input) input.value = '';
            var url = new URL(window.location.href);
            url.searchParams.delete('team');
            url.searchParams.delete('q');
            window.history.replaceState({}, '', url);
            applyTeamHighlight('');
          });
        }
        if (initialTeam) applyTeamHighlight(initialTeam);
      }

      var socket = io({ transports: ['websocket', 'polling'] });
      socket.emit('join', { eventId: eventId });
      socket.on('match:update', function (payload) {
        if (!payload || !payload.match) return;
        location.reload();
      });
    })();
  </script>
</body>
</html>
