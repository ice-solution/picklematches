<%- include('../partials/head', { title }) %>
<%- include('../partials/admin-frame-start') %>
<main class="mx-auto w-full max-w-5xl pb-12 pt-1">
  <p class="text-sm text-slate-500"><a href="/admin/events/<%= event._id %>" class="text-emerald-400 underline">← 大會設定</a></p>
  <h1 class="mt-4 text-2xl font-bold text-white">大會計分牌</h1>
  <p class="mt-2 text-sm text-slate-400">獨立於賽程場次，專供直播疊圖使用。後台改分後，顯示頁會即時更新。</p>

  <section class="mt-8 rounded border border-sky-900/60 bg-sky-950/30 p-5">
    <h2 class="font-semibold text-sky-300">匯出／OBS 連結（兩面計分牌）</h2>
    <p class="mt-2 text-xs text-slate-500">場地 1 與場地 2 各有一組直播／OBS／JSON 網址，可同時疊兩場比賽。</p>
    <% [['1', urls.display1, urls.obs1, urls.json1], ['2', urls.display2, urls.obs2, urls.json2]].forEach(function (pair) { var n = pair[0], d = pair[1], o = pair[2], j = pair[3]; %>
    <div class="mt-5 rounded border border-slate-800/80 p-4">
      <p class="text-sm font-semibold text-sky-200">場地 <%= n %></p>
      <label class="mt-3 block text-xs text-slate-500">直播顯示</label>
      <div class="mt-1 flex flex-wrap gap-2">
        <input id="url-display-<%= n %>" readonly value="<%= d %>" class="min-w-0 flex-1 rounded border border-slate-700 bg-slate-900 px-3 py-2 font-mono text-xs" />
        <button type="button" data-copy="url-display-<%= n %>" class="rounded bg-slate-700 px-3 py-2 text-sm hover:bg-slate-600">複製</button>
        <a href="<%= d %>" target="_blank" rel="noopener" class="rounded border border-slate-600 px-3 py-2 text-sm text-emerald-400 hover:bg-slate-800">預覽 ↗</a>
      </div>
      <label class="mt-3 block text-xs text-slate-500">OBS 透明</label>
      <div class="mt-1 flex flex-wrap gap-2">
        <input id="url-obs-<%= n %>" readonly value="<%= o %>" class="min-w-0 flex-1 rounded border border-slate-700 bg-slate-900 px-3 py-2 font-mono text-xs" />
        <button type="button" data-copy="url-obs-<%= n %>" class="rounded bg-slate-700 px-3 py-2 text-sm hover:bg-slate-600">複製</button>
        <a href="<%= o %>" target="_blank" rel="noopener" class="rounded border border-slate-600 px-3 py-2 text-sm text-emerald-400 hover:bg-slate-800">預覽 ↗</a>
      </div>
      <label class="mt-3 block text-xs text-slate-500">JSON</label>
      <div class="mt-1 flex flex-wrap gap-2">
        <input id="url-json-<%= n %>" readonly value="<%= j %>" class="min-w-0 flex-1 rounded border border-slate-700 bg-slate-900 px-3 py-2 font-mono text-xs" />
        <button type="button" data-copy="url-json-<%= n %>" class="rounded bg-slate-700 px-3 py-2 text-sm hover:bg-slate-600">複製</button>
        <a href="<%= j %>" target="_blank" rel="noopener" class="rounded border border-slate-600 px-3 py-2 text-sm text-sky-400 hover:bg-slate-800">開啟 ↗</a>
      </div>
    </div>
    <% }); %>
  </section>

  <section class="mt-8 rounded border border-violet-900/50 bg-violet-950/20 p-6">
    <h2 class="text-lg font-semibold text-violet-200">從賽事載入</h2>
    <p class="mt-1 text-sm text-slate-400">選擇本大會已建立的賽事場次，自動填入隊名、目前比分、局數、場地與輪次。</p>
    <p id="load-match-empty" class="mt-3 hidden text-sm text-slate-500">尚無場次。請先到「賽程／隊伍」建立賽事與場次。</p>
    <div id="load-match-form" class="mt-4 space-y-3">
      <div>
        <label class="text-xs text-slate-500">賽事</label>
        <select id="sel-tournament" class="mt-1 w-full rounded border border-slate-700 bg-slate-900 px-3 py-2 text-sm">
          <option value="">— 全部賽事 —</option>
        </select>
      </div>
      <div>
        <label class="text-xs text-slate-500">場次</label>
        <select id="sel-match" class="mt-1 w-full rounded border border-slate-700 bg-slate-900 px-3 py-2 text-sm">
          <option value="">請選擇場次</option>
        </select>
      </div>
      <div class="flex flex-wrap gap-2">
        <button type="button" id="btn-load-match" class="rounded bg-violet-600 px-4 py-2 text-sm font-semibold text-white hover:bg-violet-500">載入至計分牌</button>
        <button type="button" id="btn-sync-match" class="hidden rounded border border-violet-600 px-4 py-2 text-sm text-violet-300 hover:bg-violet-950/50">從賽程同步 ↓</button>
      </div>
      <p id="linked-match-hint" class="text-xs text-slate-500"></p>
      <p class="text-xs text-slate-600">已連結場次時：<strong class="text-slate-400">完賽</strong>或達勝局數後會<strong class="text-emerald-400">自動寫入賽程</strong>。可按「從賽程同步」拉回最新賽程比分。</p>
    </div>
  </section>

  <section class="mt-8 rounded border border-amber-900/40 bg-amber-950/20 p-6">
    <div class="flex flex-wrap items-center justify-between gap-3">
      <h2 class="text-lg font-semibold text-amber-200">即時控制</h2>
      <div class="flex rounded-lg border border-slate-700 p-0.5 text-sm" role="tablist">
        <button type="button" id="tab-slot-1" data-slot="1" class="slot-tab rounded-md bg-amber-700 px-4 py-1.5 font-semibold text-white">場地 1</button>
        <button type="button" id="tab-slot-2" data-slot="2" class="slot-tab rounded-md px-4 py-1.5 text-slate-400 hover:bg-slate-800">場地 2</button>
      </div>
    </div>
    <p class="mt-1 text-xs text-slate-500">可同時控制兩場：切換「場地 1／2」後操作。發球規則：得分方繼續發球，直至對手得分才換邊發球。</p>

    <div id="adm-preview" class="mx-auto mt-6 max-w-xl overflow-hidden rounded-lg border border-slate-600 bg-slate-900/90">
      <div id="adm-preview-subtitle" class="border-b border-slate-800 px-4 py-2 text-center text-xs font-semibold uppercase tracking-wider text-slate-400"><%= scoreboard.subtitle %></div>
      <div id="adm-row-a" class="grid grid-cols-[2rem_1fr_auto] items-center gap-3 border-b border-slate-800 px-4 py-3 <%= scoreboard.servingSide !== 'b' ? 'bg-slate-800/50' : '' %>">
        <span id="adm-serve-a" class="text-center text-lg <%= scoreboard.servingSide !== 'b' ? 'text-white' : 'text-transparent' %>">⬡</span>
        <input id="fld-team-a" type="text" value="<%= scoreboard.teamAName %>" class="min-w-0 border-0 bg-transparent text-lg font-bold uppercase text-emerald-300 focus:ring-0" />
        <span id="disp-score-a" class="text-3xl font-bold tabular-nums text-white"><%= scoreboard.scoreA %></span>
      </div>
      <div id="adm-row-b" class="grid grid-cols-[2rem_1fr_auto] items-center gap-3 px-4 py-3 <%= scoreboard.servingSide === 'b' ? 'bg-slate-800/50' : '' %>">
        <span id="adm-serve-b" class="text-center text-lg <%= scoreboard.servingSide === 'b' ? 'text-white' : 'text-transparent' %>">⬡</span>
        <input id="fld-team-b" type="text" value="<%= scoreboard.teamBName %>" class="min-w-0 border-0 bg-transparent text-lg font-bold uppercase text-sky-300 focus:ring-0" />
        <span id="disp-score-b" class="text-3xl font-bold tabular-nums text-white"><%= scoreboard.scoreB %></span>
      </div>
      <div class="flex justify-between px-4 py-2 text-xs font-semibold uppercase tracking-wider text-slate-500">
        <span id="disp-games-center">局 <%= scoreboard.gamesA %>-<%= scoreboard.gamesB %></span>
        <span id="adm-preview-round"><%= scoreboard.roundLabel %></span>
      </div>
    </div>

    <div class="mt-6 grid gap-4 sm:grid-cols-2">
      <div class="space-y-2 rounded border border-slate-700 p-3">
        <p class="text-xs text-slate-500">上列（A）— 得分後由 A 發球</p>
        <div class="flex flex-wrap gap-2">
          <button type="button" data-action="point_a" class="flex-1 rounded-lg bg-emerald-700 py-3 font-semibold text-white">A +1</button>
          <button type="button" data-action="minus_a" class="rounded-lg bg-slate-700 px-4 py-3">−1</button>
          <button type="button" data-action="serve_a" class="rounded border border-emerald-600 px-3 py-3 text-xs text-emerald-300">A 發球</button>
        </div>
      </div>
      <div class="space-y-2 rounded border border-slate-700 p-3">
        <p class="text-xs text-slate-500">下列（B）— 得分後由 B 發球</p>
        <div class="flex flex-wrap gap-2">
          <button type="button" data-action="point_b" class="flex-1 rounded-lg bg-sky-700 py-3 font-semibold text-white">B +1</button>
          <button type="button" data-action="minus_b" class="rounded-lg bg-slate-700 px-4 py-3">−1</button>
          <button type="button" data-action="serve_b" class="rounded border border-sky-600 px-3 py-3 text-xs text-sky-300">B 發球</button>
        </div>
      </div>
    </div>
    <div class="mt-4 flex flex-wrap gap-2">
      <button type="button" data-action="game_a" class="rounded-lg bg-emerald-900/80 px-4 py-2 text-sm text-emerald-200">A 贏局</button>
      <button type="button" data-action="game_b" class="rounded-lg bg-sky-900/80 px-4 py-2 text-sm text-sky-200">B 贏局</button>
    </div>
    <div class="mt-6 flex flex-wrap gap-2">
      <button type="button" data-action="finish" class="rounded bg-amber-700 px-4 py-2 text-sm font-semibold text-white hover:bg-amber-600">標記完賽</button>
      <button type="button" data-action="reset_game" class="rounded border border-slate-600 px-4 py-2 text-sm hover:bg-slate-800">本局清零</button>
      <button type="button" data-action="reset_all" class="rounded border border-rose-800 px-4 py-2 text-sm text-rose-300 hover:bg-rose-950/40">全部重置</button>
      <button type="button" data-action="swap" class="rounded border border-slate-600 px-4 py-2 text-sm hover:bg-slate-800">交換左右</button>
    </div>
    <p id="sb-msg" class="mt-4 text-center text-sm text-amber-300"></p>
  </section>

  <section class="mt-8 space-y-4 rounded border border-slate-800 bg-slate-900/40 p-6">
    <h2 class="text-lg font-semibold text-emerald-400">場次資訊</h2>
    <div class="grid gap-4 sm:grid-cols-2">
      <div>
        <label class="text-xs text-slate-500">輪次／階段（直播底部，例：準決賽）</label>
        <input id="fld-round" type="text" value="<%= scoreboard.roundLabel %>" placeholder="例：準決賽" class="mt-1 w-full rounded border border-slate-700 bg-slate-900 px-3 py-2" />
      </div>
      <div>
        <label class="text-xs text-slate-500">場地</label>
        <input id="fld-court" type="text" value="<%= scoreboard.court %>" placeholder="例：1 號場" class="mt-1 w-full rounded border border-slate-700 bg-slate-900 px-3 py-2" />
      </div>
    </div>
    <div>
      <label class="text-xs text-slate-500">副標題（直播計分牌頂部）</label>
      <input id="fld-subtitle" type="text" value="<%= scoreboard.subtitle %>" class="mt-1 w-full rounded border border-slate-700 bg-slate-900 px-3 py-2" />
    </div>
    <div class="grid gap-4 sm:grid-cols-2">
      <div>
        <label class="text-xs text-slate-500">狀態</label>
        <select id="fld-status" class="mt-1 w-full rounded border border-slate-700 bg-slate-900 px-3 py-2">
          <option value="idle" <%= scoreboard.status === 'idle' ? 'selected' : '' %>>待機</option>
          <option value="live" <%= scoreboard.status === 'live' ? 'selected' : '' %>>進行中</option>
          <option value="finished" <%= scoreboard.status === 'finished' ? 'selected' : '' %>>完賽</option>
        </select>
      </div>
      <div class="flex items-end">
        <label class="flex items-center gap-2 text-sm text-slate-300">
          <input id="fld-visible" type="checkbox" <%= scoreboard.isVisible ? 'checked' : '' %> class="rounded" />
          前台顯示比分
        </label>
      </div>
    </div>
    <button type="button" id="btn-save-meta" class="rounded bg-emerald-600 px-5 py-2 text-sm font-semibold text-white hover:bg-emerald-500">儲存場次資訊與隊名</button>
  </section>
</main>
<script>
(function () {
  var eventId = <%- JSON.stringify(String(event._id)) %>;
  var apiBase = '/api/admin/events/' + eventId + '/scoreboard';
  var currentSlot = 1;
  var boards = { 1: <%- JSON.stringify(scoreboard) %>, 2: <%- JSON.stringify(scoreboard2) %> };

  function slotQ() { return '?slot=' + currentSlot; }

  function applyBoard(sb) {
    if (!sb) return;
    boards[currentSlot] = sb;
    var serveA = sb.servingSide !== 'b';
    document.getElementById('disp-score-a').textContent = sb.scoreA;
    document.getElementById('disp-score-b').textContent = sb.scoreB;
    var ga = sb.gamesA ?? 0;
    var gb = sb.gamesB ?? 0;
    document.getElementById('disp-games-center').textContent = '局 ' + ga + '-' + gb;
    document.getElementById('fld-team-a').value = sb.teamAName;
    document.getElementById('fld-team-b').value = sb.teamBName;
    document.getElementById('fld-round').value = sb.roundLabel || '';
    document.getElementById('fld-court').value = sb.court || '';
    document.getElementById('fld-subtitle').value = sb.subtitle || '';
    document.getElementById('fld-status').value = sb.status;
    document.getElementById('fld-visible').checked = sb.isVisible !== false;

    document.getElementById('adm-preview-round').textContent = sb.roundLabel || '';
    var subEl = document.getElementById('adm-preview-subtitle');
    subEl.textContent = sb.subtitle || '';
    subEl.classList.toggle('hidden', !sb.subtitle);
    var rowA = document.getElementById('adm-row-a');
    var rowB = document.getElementById('adm-row-b');
    rowA.classList.toggle('bg-slate-800/50', serveA);
    rowB.classList.toggle('bg-slate-800/50', !serveA);
    document.getElementById('adm-serve-a').className = 'text-center text-lg ' + (serveA ? 'text-white' : 'text-transparent');
    document.getElementById('adm-serve-b').className = 'text-center text-lg ' + (!serveA ? 'text-white' : 'text-transparent');
  }

  function msg(t) {
    var el = document.getElementById('sb-msg');
    el.textContent = t || '';
    if (t) setTimeout(function () { if (el.textContent === t) el.textContent = ''; }, 2000);
  }

  function setActiveSlotTab() {
    document.querySelectorAll('.slot-tab').forEach(function (btn) {
      var on = Number(btn.getAttribute('data-slot')) === currentSlot;
      btn.classList.toggle('bg-amber-700', on);
      btn.classList.toggle('text-white', on);
      btn.classList.toggle('font-semibold', on);
      btn.classList.toggle('text-slate-400', !on);
    });
  }

  function switchSlot(n) {
    currentSlot = n === 2 ? 2 : 1;
    setActiveSlotTab();
    applyBoard(boards[currentSlot]);
    fetchMatchCatalog();
  }

  document.querySelectorAll('.slot-tab').forEach(function (btn) {
    btn.addEventListener('click', function () {
      switchSlot(Number(btn.getAttribute('data-slot')));
    });
  });

  async function patch(body) {
    body.slot = currentSlot;
    var res = await fetch(apiBase + slotQ(), {
      method: 'PATCH',
      headers: { 'Content-Type': 'application/json' },
      credentials: 'same-origin',
      body: JSON.stringify(body),
    });
    var data = await res.json();
    if (!res.ok) throw new Error(data.error || 'failed');
    onBoardSaved(data);
    return data;
  }

  async function action(name) {
    var res = await fetch(apiBase + '/action' + slotQ(), {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      credentials: 'same-origin',
      body: JSON.stringify({ action: name, slot: currentSlot }),
    });
    var data = await res.json();
    if (!res.ok) throw new Error(data.error || 'failed');
    onBoardSaved(data);
  }

  document.querySelectorAll('[data-action]').forEach(function (btn) {
    btn.addEventListener('click', function () {
      action(btn.getAttribute('data-action')).catch(function (e) { msg(e.message); });
    });
  });

  document.getElementById('btn-save-meta').addEventListener('click', function () {
    patch({
      teamAName: document.getElementById('fld-team-a').value,
      teamBName: document.getElementById('fld-team-b').value,
      roundLabel: document.getElementById('fld-round').value,
      court: document.getElementById('fld-court').value,
      subtitle: document.getElementById('fld-subtitle').value,
      status: document.getElementById('fld-status').value,
      isVisible: document.getElementById('fld-visible').checked,
    }).catch(function (e) { msg(e.message); });
  });

  document.querySelectorAll('[data-copy]').forEach(function (btn) {
    btn.addEventListener('click', function () {
      var id = btn.getAttribute('data-copy');
      var input = document.getElementById(id);
      navigator.clipboard.writeText(input.value).then(function () { msg('已複製'); });
    });
  });

  var matchCatalog = { tournaments: [], matches: [], linkedMatchId: null };

  function statusTag(s) {
    var map = { scheduled: '未開', live: '進行中', finished: '完賽', postponed: '延期', cancelled: '取消' };
    return map[s] || s;
  }

  function fillMatchOptions() {
    var tSel = document.getElementById('sel-tournament');
    var mSel = document.getElementById('sel-match');
    var tid = tSel.value;
    var list = matchCatalog.matches.filter(function (m) {
      return !tid || m.tournamentId === tid;
    });
    mSel.innerHTML = '<option value="">請選擇場次</option>';
    list.forEach(function (m) {
      var opt = document.createElement('option');
      opt.value = m.id;
      opt.textContent = '[' + statusTag(m.status) + '] ' + m.label;
      if (m.id === matchCatalog.linkedMatchId) opt.selected = true;
      mSel.appendChild(opt);
    });
  }

  function updateLinkedHint() {
    var hint = document.getElementById('linked-match-hint');
    var syncBtn = document.getElementById('btn-sync-match');
    if (!matchCatalog.linkedMatchId) {
      hint.textContent = '';
      syncBtn.classList.add('hidden');
      return;
    }
    var m = matchCatalog.matches.find(function (x) { return x.id === matchCatalog.linkedMatchId; });
    hint.textContent = m ? '已連結場次：' + m.label + '（完賽自動寫入賽程）' : '已連結場次 ID：' + matchCatalog.linkedMatchId;
    syncBtn.classList.remove('hidden');
  }

  function onBoardSaved(data) {
    applyBoard(data.scoreboard);
    if (data.matchSynced) {
      msg('已寫入賽程');
    } else {
      msg('已更新');
    }
  }

  function initMatchPicker(data) {
    matchCatalog.tournaments = data.tournaments || [];
    matchCatalog.matches = data.matches || [];
    matchCatalog.linkedMatchId = data.linkedMatchId || null;

    var empty = document.getElementById('load-match-empty');
    var form = document.getElementById('load-match-form');
    if (!matchCatalog.matches.length) {
      empty.classList.remove('hidden');
      form.classList.add('hidden');
      return;
    }
    empty.classList.add('hidden');
    form.classList.remove('hidden');

    var tSel = document.getElementById('sel-tournament');
    tSel.innerHTML = '<option value="">— 全部賽事 —</option>';
    matchCatalog.tournaments.forEach(function (t) {
      var opt = document.createElement('option');
      opt.value = t.id;
      opt.textContent = t.name;
      tSel.appendChild(opt);
    });
  if (matchCatalog.linkedMatchId) {
      var linked = matchCatalog.matches.find(function (m) { return m.id === matchCatalog.linkedMatchId; });
      if (linked) tSel.value = linked.tournamentId;
    }
    fillMatchOptions();
    updateLinkedHint();
  }

  async function loadFromMatch(matchId) {
    var res = await fetch(apiBase + '/load-match' + slotQ(), {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      credentials: 'same-origin',
      body: JSON.stringify({ matchId: matchId, slot: currentSlot }),
    });
    var data = await res.json();
    if (!res.ok) throw new Error(data.error || 'failed');
    onBoardSaved(data);
    matchCatalog.linkedMatchId = matchId;
    updateLinkedHint();
    if (!data.matchSynced) {
      msg('已從賽事載入：' + (data.match && data.match.label ? data.match.label : ''));
    }
  }

  document.getElementById('sel-tournament').addEventListener('change', fillMatchOptions);

  document.getElementById('btn-load-match').addEventListener('click', function () {
    var matchId = document.getElementById('sel-match').value;
    if (!matchId) { msg('請先選擇場次'); return; }
    loadFromMatch(matchId).catch(function (e) { msg(e.message); });
  });

  document.getElementById('btn-sync-match').addEventListener('click', function () {
    if (!matchCatalog.linkedMatchId) { msg('尚未連結場次'); return; }
    loadFromMatch(matchCatalog.linkedMatchId).catch(function (e) { msg(e.message); });
  });

  function fetchMatchCatalog() {
    return fetch(apiBase + '/matches' + slotQ(), { credentials: 'same-origin' })
      .then(function (r) { return r.json(); })
      .then(function (data) {
        if (data.ok) initMatchPicker(data);
      })
      .catch(function () { msg('無法載入賽事列表'); });
  }

  applyBoard(boards[1]);
  fetchMatchCatalog();
})();
</script>
<%- include('../partials/admin-frame-end') %>
