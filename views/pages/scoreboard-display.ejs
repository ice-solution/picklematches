<%- include('../partials/head', { title }) %>
<% var obs = typeof obsMode !== 'undefined' && obsMode; %>
<% var transp = typeof transparent !== 'undefined' && transparent; %>
<% var serveA = scoreboard.servingSide !== 'b'; %>
<% var ga0 = scoreboard.gamesA ?? 0; %>
<% var gb0 = scoreboard.gamesB ?? 0; %>
<% var gameNum = ga0 + gb0 + 1;
   var footerGame = scoreboard.roundLabel || '';
   if (!footerGame) {
     if (gameNum === 1) footerGame = '1ST GAME';
     else if (gameNum === 2) footerGame = '2ND GAME';
     else if (gameNum === 3) footerGame = '3RD GAME';
     else footerGame = gameNum + 'TH GAME';
   } %>
<style>
  .sb-wrap {
    font-family: 'Noto Sans TC', system-ui, sans-serif;
    width: min(100%, 56rem);
    border-radius: 0.35rem;
    overflow: hidden;
    box-shadow: 0 12px 40px rgba(0, 0, 0, 0.35);
    border: 3px solid rgba(255, 255, 255, 0.85);
  }
  .sb-top,
  .sb-bottom {
    background: linear-gradient(180deg, #b8daf7 0%, #9ec9f5 100%);
    color: #0f172a;
  }
  .sb-top {
    padding: 0.65rem 1rem 0.6rem;
    text-align: center;
  }
  .sb-top:not(.has-subtitle) {
    display: none;
  }
  .sb-subtitle {
    margin: 0;
    font-size: clamp(1.35rem, 4vw, 2rem);
    font-weight: 900;
    letter-spacing: 0.2em;
    color: #fff;
    text-shadow: 0 1px 2px rgba(15, 23, 42, 0.25);
    line-height: 1.15;
    text-transform: uppercase;
  }
  .sb-teams {
    display: grid;
    grid-template-columns: 1fr auto 1fr;
    min-height: 10rem;
  }
  .sb-team {
    display: flex;
    flex-direction: column;
    min-width: 0;
  }
  .sb-team-label {
    padding: 0.35rem 0.5rem;
    text-align: center;
    font-size: clamp(0.75rem, 2.2vw, 1rem);
    font-weight: 900;
    letter-spacing: 0.12em;
    color: #0f172a;
  }
  .sb-team-a .sb-team-label { background: #f8c4d4; }
  .sb-team-b .sb-team-label { background: #b8daf7; }
  .sb-team-names {
    padding: 0.3rem 0.45rem;
    text-align: center;
    font-size: clamp(0.65rem, 1.8vw, 0.85rem);
    font-weight: 700;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: #fff;
    line-height: 1.25;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }
  .sb-team-a .sb-team-names { background: #e87890; }
  .sb-team-b .sb-team-names { background: #5ba3d9; }
  .sb-score-panel {
    position: relative;
    flex: 1;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    background: rgba(8, 12, 20, 0.82);
    padding: 0.5rem 0.35rem 1.6rem;
    min-height: 7.5rem;
  }
  .sb-serving {
    position: absolute;
    top: 0.35rem;
    left: 50%;
    transform: translateX(-50%);
    display: flex;
    align-items: center;
    gap: 0.2rem;
    font-size: clamp(0.55rem, 1.5vw, 0.72rem);
    font-weight: 900;
    letter-spacing: 0.1em;
    color: #fde047;
    opacity: 0;
    transition: opacity 0.15s;
    white-space: nowrap;
  }
  .sb-team.is-serving .sb-serving { opacity: 1; }
  .sb-serving-arrow {
    font-size: 0.65em;
    line-height: 1;
  }
  .sb-score {
    font-size: clamp(3rem, 12vw, 5.5rem);
    font-weight: 900;
    font-variant-numeric: tabular-nums;
    line-height: 1;
    color: #fff;
    letter-spacing: -0.02em;
  }
  .sb-sets {
    position: absolute;
    bottom: 0.35rem;
    left: 0;
    right: 0;
    text-align: center;
    font-size: clamp(0.6rem, 1.6vw, 0.78rem);
    font-weight: 800;
    letter-spacing: 0.14em;
    color: rgba(255, 255, 255, 0.92);
  }
  .sb-divider {
    width: 3px;
    background: #fff;
    display: flex;
    align-items: center;
    justify-content: center;
    position: relative;
  }
  .sb-divider-arrow {
    position: absolute;
    font-size: 0.85rem;
    color: #fff;
    line-height: 1;
    opacity: 0;
    transition: opacity 0.15s, transform 0.15s;
    text-shadow: 0 0 4px rgba(0, 0, 0, 0.8);
  }
  .sb-divider-arrow.to-a {
    opacity: 1;
    transform: translateX(-3px) rotate(180deg);
  }
  .sb-divider-arrow.to-b {
    opacity: 1;
    transform: translateX(3px);
  }
  .sb-bottom {
    position: relative;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 0.45rem 5rem 0.45rem 0.85rem;
    font-weight: 800;
    letter-spacing: 0.12em;
    text-transform: uppercase;
  }
  .sb-game-label {
    text-align: center;
    font-size: clamp(0.75rem, 2vw, 1rem);
  }
  .sb-footer-meta {
    position: absolute;
    right: 0.85rem;
    font-size: clamp(0.65rem, 1.6vw, 0.85rem);
    font-variant-numeric: tabular-nums;
  }
  .sb-footer-meta:empty { display: none; }
  <% if (obs) { %>
  .sb-wrap { width: min(100%, 64rem); border-width: 4px; }
  .sb-score-panel { min-height: 9rem; }
  <% } %>
</style>
<body class="<%= transp ? 'bg-transparent' : 'bg-slate-900' %> min-h-screen">
  <main id="sb-root" class="flex min-h-screen items-center justify-center p-4 <%= obs ? 'p-2' : 'p-8' %>">
    <div id="sb-card" class="sb-wrap">
      <header class="sb-top <%= scoreboard.subtitle ? 'has-subtitle' : '' %>">
        <p id="sb-subtitle" class="sb-subtitle"><%= scoreboard.subtitle || '' %></p>
      </header>

      <div class="sb-teams">
        <div id="sb-col-a" class="sb-team sb-team-a <%= serveA ? 'is-serving' : '' %>">
          <div class="sb-team-label">TEAM A</div>
          <div id="sb-team-a" class="sb-team-names"><%= scoreboard.teamAName %></div>
          <div class="sb-score-panel">
            <div class="sb-serving" aria-hidden="true">
              <span class="sb-serving-arrow">▲</span><span>SERVING</span>
            </div>
            <div id="sb-score-a" class="sb-score"><%= scoreboard.scoreA %></div>
            <div class="sb-sets">SETS: <span id="sb-sets-a"><%= ga0 %></span></div>
          </div>
        </div>

        <div class="sb-divider" aria-hidden="true">
          <span id="sb-divider-arrow" class="sb-divider-arrow <%= serveA ? 'to-a' : 'to-b' %>">▶</span>
        </div>

        <div id="sb-col-b" class="sb-team sb-team-b <%= !serveA ? 'is-serving' : '' %>">
          <div class="sb-team-label">TEAM B</div>
          <div id="sb-team-b" class="sb-team-names"><%= scoreboard.teamBName %></div>
          <div class="sb-score-panel">
            <div class="sb-serving" aria-hidden="true">
              <span class="sb-serving-arrow">▲</span><span>SERVING</span>
            </div>
            <div id="sb-score-b" class="sb-score"><%= scoreboard.scoreB %></div>
            <div class="sb-sets">SETS: <span id="sb-sets-b"><%= gb0 %></span></div>
          </div>
        </div>
      </div>

      <footer class="sb-bottom">
        <span id="sb-game-label" class="sb-game-label"><%= footerGame %></span>
        <span id="sb-footer-meta" class="sb-footer-meta"><%= scoreboard.court || '' %></span>
      </footer>
    </div>
    <p id="sb-hidden" class="mt-4 hidden text-slate-500">待機中</p>
  </main>
  <script src="/socket.io/socket.io.js"></script>
  <script>
    (function () {
      var eventId = <%- JSON.stringify(eventIdStr) %>;
      var scoreboardSlot = <%- JSON.stringify(typeof scoreboardSlot !== 'undefined' ? scoreboardSlot : 1) %>;

      function ordinalGame(n) {
        var s = String(n);
        if (n === 1) return '1ST GAME';
        if (n === 2) return '2ND GAME';
        if (n === 3) return '3RD GAME';
        return s + 'TH GAME';
      }

      function applyBoard(sb) {
        if (!sb) return;
        var visible = sb.isVisible !== false;
        var serveA = sb.servingSide !== 'b';
        var ga = sb.gamesA ?? 0;
        var gb = sb.gamesB ?? 0;

        var sub = document.getElementById('sb-subtitle');
        var top = sub.closest('.sb-top');
        sub.textContent = sb.subtitle || '';
        if (top) top.classList.toggle('has-subtitle', !!sb.subtitle);

        document.getElementById('sb-team-a').textContent = sb.teamAName || 'TEAM A';
        document.getElementById('sb-team-b').textContent = sb.teamBName || 'TEAM B';
        document.getElementById('sb-score-a').textContent = sb.scoreA ?? 0;
        document.getElementById('sb-score-b').textContent = sb.scoreB ?? 0;
        document.getElementById('sb-sets-a').textContent = ga;
        document.getElementById('sb-sets-b').textContent = gb;

        document.getElementById('sb-col-a').classList.toggle('is-serving', serveA);
        document.getElementById('sb-col-b').classList.toggle('is-serving', !serveA);

        var arrow = document.getElementById('sb-divider-arrow');
        arrow.classList.toggle('to-a', serveA);
        arrow.classList.toggle('to-b', !serveA);

        var gameLabel = document.getElementById('sb-game-label');
        gameLabel.textContent = sb.roundLabel || ordinalGame(ga + gb + 1);

        document.getElementById('sb-footer-meta').textContent = sb.court || '';

        document.getElementById('sb-root').style.opacity = visible ? '1' : '0.35';
        document.getElementById('sb-hidden').classList.toggle('hidden', visible);
      }

      applyBoard(<%- JSON.stringify(scoreboard) %>);

      var socket = io({ transports: ['websocket', 'polling'] });
      socket.emit('join', { scoreboardEventId: eventId, scoreboardSlot: scoreboardSlot });
      socket.on('scoreboard:update', function (payload) {
        if (!payload || !payload.scoreboard) return;
        if (payload.slot != null && payload.slot !== scoreboardSlot) return;
        applyBoard(payload.scoreboard);
      });
    })();
  </script>
</body>
</html>
